{
  "name": "mfcmouseeffect-webui-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm run build:dialog && pnpm run build:shell && pnpm run build:workspace && pnpm run build:general && pnpm run build:effects && pnpm run build:text && pnpm run build:trail && pnpm run build:indicator && pnpm run build:automation && pnpm run build:wasm && node scripts/copy-output.mjs",
    "build:dialog": "vite build --mode dialog",
    "build:shell": "vite build --mode shell",
    "build:workspace": "vite build --mode workspace",
    "build:general": "vite build --mode general",
    "build:effects": "vite build --mode effects",
    "build:text": "vite build --mode text",
    "build:trail": "vite build --mode trail",
    "build:indicator": "vite build --mode indicator",
    "build:automation": "vite build --mode automation",
    "build:wasm": "vite build --mode wasm",
    "dev": "vite",
    "test:automation-platform": "node scripts/test-automation-platform.mjs",
    "test:effects-profile-model": "node scripts/test-effects-profile-model.mjs",
    "test:wasm-error-model": "node scripts/test-wasm-action-error-model.mjs",
    "test:wasm-state-model": "node scripts/test-wasm-state-model.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "vite": "^5.4.0"
  }
}
